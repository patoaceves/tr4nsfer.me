{
  "version": 2,
  "builds": [
    { "src": "api/card.js", "use": "@vercel/node" },
    { "src": "**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/app",                        "dest": "/app.html" },
    { "src": "/auth",                       "dest": "/auth.html" },
    { "src": "/portal",                     "dest": "/portal.html" },
    { "src": "/([a-z0-9][a-z0-9-]{2,19})", "dest": "/api/card?slug=$1" },
    { "src": "/",                           "dest": "/index.html" }
  ]
}
